{
  "manifest_version": 3,
  "name": "Drift",
  "version": "1.0.0",
  "description": "Set your intention. Watch your focus. See the truth.",

  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [{
    "matches": ["http://*/*", "https://*/*"],
    "js": ["content/tracker.js"],
    "run_at": "document_idle"
  }],

  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}